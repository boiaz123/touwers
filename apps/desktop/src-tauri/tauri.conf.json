{
  "productName": "Touwers",
  "version": "1.0.1",
  "identifier": "com.touwers.game",
  "build": {
    "beforeBuildCommand": { "script": "npm run build", "cwd": "../../.." },
    "beforeDevCommand": { "script": "npm run dev", "cwd": "../../.." },
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../../dist"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "decorations": false,
        "maximized": true,
        "title": "Touwers",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "alwaysOnTop": false,
        "focus": true,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection,CalculateNativeWinOcclusion"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "Touwers",
    "copyright": "Copyright © 2026 Touwers",
    "category": "StrategyGame",
    "licenseFile": "installer/LICENSE.txt",
    "shortDescription": "A strategic tower defense game",
    "longDescription": "Touwers is a browser-based tower defense game featuring a grid-based tower placement system, wave-based enemy progression, and a resolution-agnostic architecture. Build towers, defend your castle, and conquer campaigns.",
    "windows": {
      "allowDowngrades": false,
      "wix": {
        "language": "en-US",
        "upgradeCode": "3A7F2E91-B04C-4D1A-9C88-A6F53D2E7B40",
        "bannerPath": "installer/wix-banner.bmp",
        "dialogImagePath": "installer/wix-dialog.bmp"
      }
    }
  }
}
